<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView style="@style/FieldLabel" android:text="CMR / Box / APO" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp" android:orientation="horizontal">
        <EditText android:id="@+id/editUsaCmr" style="@style/FieldInput" android:layout_width="0dp" android:layout_weight="1" android:hint="CMR" android:layout_marginEnd="4dp" android:inputType="text" />
        <EditText android:id="@+id/editUsaBox" style="@style/FieldInput" android:layout_width="0dp" android:layout_weight="1" android:hint="Box" android:layout_marginEnd="4dp" android:inputType="text" />
        <EditText android:id="@+id/editUsaApo" style="@style/FieldInput" android:layout_width="0dp" android:layout_weight="1" android:hint="APO" android:inputType="text" />
    </LinearLayout>

    <TextView style="@style/FieldLabel" android:text="City" />
    <EditText android:id="@+id/editUsaCity" style="@style/FieldInput" android:layout_marginBottom="4dp" android:inputType="text" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
            <TextView style="@style/FieldLabel" android:text="State" />
            <EditText android:id="@+id/editUsaState" style="@style/FieldInput" android:inputType="text" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="@style/FieldLabel" android:text="Zip Code" />
            <EditText android:id="@+id/editUsaZip" style="@style/FieldInput" android:inputType="number" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>