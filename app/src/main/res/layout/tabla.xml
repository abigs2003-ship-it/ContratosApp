<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_height="match_parent">
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp">

        <LinearLayout
            android:id="@+id/layoutTablaPuntos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingEnd="12dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn1erTabla"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    android:text="1er Tabla"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:strokeColor="#BDBDBD"
                    app:strokeWidth="1dp" />
                <FrameLayout android:id="@+id/containerTabla" android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginTop="8dp" android:background="#F5F5F5" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Disponibles" android:textColor="#FF2C2C" android:textSize="15sp" android:textStyle="bold" />
                    <Spinner android:id="@+id/spDisponibles" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_card" />
                </LinearLayout>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="Puntos Adquiridos" android:textColor="#FF2C2C" android:textSize="15sp" android:textStyle="bold" />
                    <EditText android:id="@+id/editPuntosAdquiridos" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:background="@drawable/bg_card" android:paddingHorizontal="8dp" android:inputType="number" android:textSize="15sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditarTabla"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:backgroundTint="@color/white"
                    android:text="Editar Tabla"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconTint="@color/black"
                    app:strokeColor="#BDBDBD"
                    app:strokeWidth="1dp" />

                <RadioGroup android:id="@+id/rgTablaModo" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                    <RadioButton android:id="@+id/rbPredeterminada" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Predeterminada" android:textSize="15sp" />
                    <RadioButton android:id="@+id/rbModificada" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Modificada" android:textSize="15sp" />
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:background="@color/white"
            android:paddingHorizontal="4dp"
            android:text="Tabla de Puntos"
            android:textColor="#B71C1C"
            android:textSize="15sp"
            android:textStyle="bold" />
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>