<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Street Address"
        android:fontFamily="serif"
        android:textSize="15sp"
        android:textColor="@color/pacificagris"
        android:textStyle="bold" />
    <EditText
        android:id="@+id/editStreetPO"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:textSize="15sp"
        android:background="@drawable/bg_input"
        android:paddingStart="12dp"
        android:layout_marginBottom="12dp"
        android:inputType="textCapWords" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="P.O. Box"
                android:fontFamily="serif"
                android:textSize="15sp"
                android:textColor="@color/pacificagris"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/editPO"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:textSize="15sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:inputType="textCapWords" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="City"
                android:fontFamily="serif"
                android:textSize="15sp"
                android:textColor="@color/pacificagris"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/editCity"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:textSize="15sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:inputType="textCapWords"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="State"
                android:fontFamily="serif"
                android:textSize="15sp"
                android:textColor="@color/pacificagris"
                android:textStyle="bold" />
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_input">
                <Spinner
                    android:id="@+id/spinnerEstadoUSA"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:paddingStart="12dp" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_abajo"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    app:tint="#64748B" />
            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zip Code"
                android:fontFamily="serif"
                android:textSize="15sp"
                android:textColor="@color/pacificagris"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/editZipCode2"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:textSize="15sp"
                android:background="@drawable/bg_input"
                android:paddingStart="12dp"
                android:imeOptions="actionDone"
                android:maxLength="5"
                android:inputType="number" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Country"
        android:fontFamily="serif"
        android:textSize="15sp"
        android:textColor="@color/pacificagris"
        android:textStyle="bold" />
    <EditText
        android:id="@+id/editCountryUSA_PO"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:textSize="15sp"
        android:background="@drawable/bg_input"
        android:paddingStart="12dp"
        android:text="USA"
        android:enabled="false"
        android:inputType="text" />
</LinearLayout>
