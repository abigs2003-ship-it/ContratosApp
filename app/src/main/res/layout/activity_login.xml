<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#080C24"
    tools:context=".Login.LoginActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/loginCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:elevation="8dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_max="500dp"
            app:layout_constraintWidth_percent="0.95">

            <ImageView
                android:id="@+id/icono_pacifica"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_marginBottom="16dp"
                android:contentDescription="@string/resort_logo"
                app:srcCompat="@drawable/icono_pacifica"
                app:tint="#00BCD4" />

            <TextView
                android:id="@+id/pacificalogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-thin"
                android:text="Pacifica Resort"
                android:layout_marginBottom="20dp"
                android:textColor="@color/white"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:fontFamily="sans-serif-medium"
                android:text="Iniciar sesión"
                android:textColor="@color/white"
                android:textSize="17sp" />

            <EditText
                android:id="@+id/editUsuario"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="12dp"
                android:background="@drawable/bg_input_field"
                android:hint="Usuario"
                android:importantForAutofill="no"
                android:inputType="textPersonName"
                android:paddingHorizontal="20dp"
                android:textColor="@color/white"
                android:textColorHint="#CCFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editContrasena"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_input_field"
                android:hint="Contraseña"
                android:importantForAutofill="no"
                android:inputType="textPassword"
                android:paddingHorizontal="15dp"
                android:textColor="@color/white"
                android:textColorHint="#CCFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEntrar"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_boton_login"
                android:fontFamily="sans-serif-medium"
                android:text="Entrar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>