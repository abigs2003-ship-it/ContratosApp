<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pacificagris">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_section_header"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:layout_marginStart="12dp"
                    android:text="@string/domicilioform"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMexico"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/mexico"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        app:backgroundTint="#0A0E21"
                        android:textColor="@color/white"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="8dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUSA"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/usa"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/white"
                        android:textColor="#1E293B"
                        app:strokeColor="#CBD5E1"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="8dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCanada"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/canada"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/white"
                        android:textColor="#1E293B"
                        app:strokeColor="#CBD5E1"
                        android:layout_marginEnd="6dp"
                        app:cornerRadius="8dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOtro"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/otro"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/white"
                        android:textColor="#1E293B"
                        app:strokeColor="#CBD5E1"
                        app:cornerRadius="8dp" />
                </LinearLayout>

                <FrameLayout
                    android:id="@+id/addressContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageButton
                        android:id="@+id/btnLimpiarDomicilio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_html_btn_outline"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="8dp"
                        android:src="@drawable/ic_trash"
                        app:tint="@color/black"
                        app:backgroundTint="@null" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- TELÉFONOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_section_header"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_phone"
                    app:tint="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/telefonoform"
                    android:fontFamily="serif"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="" android:textSize="15sp" android:textStyle="bold" android:textColor="#64748B" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.6"
                        android:text="@string/lada"
                        android:textSize="15sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:textColor="#64748B"
                        android:gravity="center" />
                    <TextView
                        android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.5" android:text="" android:textSize="15sp" android:textStyle="bold" android:textColor="#64748B" />
                    <TextView
                        android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:text="WhatsApp" android:textSize="15sp" android:textStyle="bold" android:textColor="#64748B" android:gravity="center" />
                    <TextView
                        android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8" android:text="@string/principal" android:textSize="15sp" android:textStyle="bold" android:textColor="#64748B" android:gravity="center" />
                </LinearLayout>

                <!-- Row 1: Casa 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="@string/casa1"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:inputType=""
                        android:textColor="@color/pacificagris"/>
                    <EditText 
                        android:id="@+id/etLadaCasa1"
                        android:inputType="phone"
                        android:nextFocusForward="@id/etNumeroCasa1"
                        android:imeOptions="actionNext"
                        android:maxLength="5"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="0.6" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <EditText
                        android:id="@+id/etNumeroCasa1"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:imeOptions="actionDone"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1.5" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <CheckBox android:id="@+id/cbWsCasa1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="No" android:textSize="11sp" />
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <RadioButton
                            android:id="@+id/rbCasa1"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Row 2: Casa 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="@string/casa2"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:textColor="@color/pacificagris" />
                    <EditText
                        android:id="@+id/etLadaCasa2"
                        android:inputType="phone"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/etNumeroCasa2"
                        android:maxLength="5"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="0.6" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <EditText
                        android:id="@+id/etNumeroCasa2"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:imeOptions="actionDone"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1.5" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <CheckBox android:id="@+id/cbWsCasa2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="No" android:textSize="11sp" />
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <RadioButton
                            android:id="@+id/rbCasa2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Row 3: Oficina 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="@string/oficina1"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:textColor="@color/pacificagris" />
                    <EditText android:id="@+id/etLadaOficina1"
                        android:inputType="phone"
                        android:maxLength="5"
                        android:layout_width="0dp"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/etNumeroOficina1"
                        android:layout_height="36dp"
                        android:layout_weight="0.6"
                        android:background="@drawable/bg_input"
                        android:textSize="15sp"
                        android:gravity="center"
                        android:layout_marginEnd="4dp" />
                    <EditText android:id="@+id/etNumeroOficina1"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:imeOptions="actionDone"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1.5" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <CheckBox android:id="@+id/cbWsOficina1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="No" android:textSize="11sp" />
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <RadioButton
                            android:id="@+id/rbOficina1"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Row 4: Oficina 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="@string/oficina2"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:textColor="@color/pacificagris" />
                    <EditText android:id="@+id/etLadaOficina2"
                        android:inputType="phone"
                        android:maxLength="5"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/etNumeroOficina2"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="0.6" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <EditText android:id="@+id/etNumeroOficina2"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:imeOptions="actionDone"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1.5" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <CheckBox android:id="@+id/cbWsOficina2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="No" android:textSize="11sp" />
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <RadioButton
                            android:id="@+id/rbOficina2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Row 5: Celular 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="@string/celular1"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:textColor="@color/pacificagris" />
                    <EditText android:id="@+id/etLadaCel1"
                        android:inputType="phone"
                        android:maxLength="5"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/etNumeroCel1"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="0.6" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <EditText android:id="@+id/etNumeroCel1"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:imeOptions="actionDone"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1.5" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <CheckBox android:id="@+id/cbWsCel1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="No" android:textSize="11sp" />
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <RadioButton
                            android:id="@+id/rbCelular1"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Row 6: Celular 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="@string/celular2"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:textColor="@color/pacificagris" />
                    <EditText android:id="@+id/etLadaCel2"
                        android:inputType="phone"
                        android:maxLength="5"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/etNumeroCel2"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="0.6" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <EditText android:id="@+id/etNumeroCel2"
                        android:inputType="phone"
                        android:imeOptions="actionDone"
                        android:maxLength="9"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1.5" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <CheckBox android:id="@+id/cbWsCel2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="No" android:textSize="11sp" />
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <RadioButton
                            android:id="@+id/rbCelular2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Row 7: Mensajes -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:text="@string/mensajes"
                        android:textStyle="bold"
                        android:fontFamily="serif"
                        android:gravity="start"
                        android:textSize="15sp"
                        android:textColor="@color/pacificagris" />
                    <EditText android:id="@+id/etLadaMensajes"
                        android:inputType="phone"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/etNumeroMensajes"
                        android:maxLength="5"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="0.6" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <EditText android:id="@+id/etNumeroMensajes"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:imeOptions="actionDone"
                        android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1.5" android:background="@drawable/bg_input" android:textSize="15sp" android:gravity="center" android:layout_marginEnd="4dp" />
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <CheckBox android:id="@+id/cbWsMensajes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="No" android:textSize="11sp" />
                    </FrameLayout>
                    <FrameLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="0.8">
                        <RadioButton
                            android:id="@+id/rbMensajes"
                            android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnLimpiarTelefonos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_html_btn_outline"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:src="@drawable/ic_trash"
                    app:tint="@color/black"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </LinearLayout>

        <!-- SECTION: CORREO ELECTRÓNICO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_section_header"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_email"
                    app:tint="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/correo"
                    android:fontFamily="serif"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email 1"
                        android:textColor="@color/pacificagris"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />
                </LinearLayout>
                <EditText android:id="@+id/etEmail1"
                    android:imeOptions="actionDone"
                    android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_input" android:hint="correo@ejemplo.com" android:paddingStart="12dp" android:textSize="15sp" android:layout_marginBottom="12dp"
                    android:inputType="text"/>

                <!-- Email 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView
                        android:textColor="@color/pacificagris"
                        android:fontFamily="serif"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email 2" android:textSize="15sp" android:textStyle="bold" android:layout_marginStart="8dp" />
                </LinearLayout>
                <EditText android:inputType="text"
                    android:imeOptions="actionDone"

                    android:id="@+id/etEmail2" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_input" android:hint="correo@ejemplo.com" android:paddingStart="12dp" android:textSize="15sp" android:layout_marginBottom="12dp" />

                <!-- Email 3 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email 3"
                        android:textColor="@color/pacificagris"
                        android:fontFamily="serif"
                        android:textSize="15sp"
                        android:textStyle="bold" android:layout_marginStart="8dp" />
                </LinearLayout>
                <EditText android:inputType="text"


                    android:id="@+id/etEmail3" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_input" android:hint="correo@ejemplo.com" android:paddingStart="12dp" android:textSize="15sp" android:layout_marginBottom="12dp" />

                <!-- Email 4 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                    <TextView android:textColor="@color/pacificagris"
                        android:fontFamily="serif"
                        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Email 4" android:textSize="15sp" android:textStyle="bold" android:layout_marginStart="8dp" />
                </LinearLayout>
                <EditText android:inputType="text"


                    android:id="@+id/etEmail4" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_input" android:hint="correo@ejemplo.com" android:paddingStart="12dp" android:textSize="15sp" android:layout_marginBottom="16dp" />

                <CheckBox
                    android:id="@+id/cbNoCorreo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/pacificagris"
                    android:fontFamily="serif"
                    android:text="@string/nocorreo"
                    android:textSize="15sp"
                    android:layout_marginBottom="16dp" />
                <ImageButton
                    android:id="@+id/btnLimpiarEmails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_html_btn_outline"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:src="@drawable/ic_trash"
                    app:tint="@color/black"
                    app:backgroundTint="@null" />
            </LinearLayout>
        </LinearLayout>

        <!-- SECTION: NACIONALIDAD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_section_header"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_world"
                    app:tint="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/nacionalidad"
                    android:fontFamily="serif"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_section_content"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_input">
                    <Spinner
                        android:id="@+id/spinnerNacionalidad"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:paddingStart="12dp" />
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_abajo"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        app:tint="#64748B" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/AceptarTarea"
            android:background="@drawable/btn_continuar"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_cont"
            app:iconSize="20dp"
            android:text="@string/continuar"
            android:textSize="15dp"
            app:iconGravity="textEnd" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>