<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pacificagris"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_section_header"
            android:gravity="center_vertical"
            android:padding="14dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_tabla"
                android:layout_gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/tablaamor"
                android:fontFamily="serif"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.03" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_section_content"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/white"
                android:baselineAligned="false">

                <!-- Left: Inputs -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/datosgen"
                        android:fontFamily="serif"
                        android:textColor="@color/pacificagris"
                        android:gravity="center"
                        android:textSize="15dp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="5dp" />
                    
                    <View
                        android:layout_height="3dp"
                        android:layout_width="match_parent"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="14dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="7dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tipoperiodo"
                                android:fontFamily="serif"
                                android:textColor="#C0392B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="5dp" />
                            <Spinner
                                android:id="@+id/spinnerTipoPeriodo"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_spinner" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="7dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/fechaprimer"
                                android:fontFamily="serif"
                                android:textColor="#C0392B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="5dp" />
                            <EditText
                                android:id="@+id/etFechaPrimerPago"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_input"
                                android:hint="DD/MM/AAAA"
                                android:paddingHorizontal="14dp"
                                android:textSize="15sp"
                                android:inputType="date"
                                android:focusable="false"
                                android:clickable="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="7dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/montofinanciar"
                                android:fontFamily="serif"
                                android:textColor="#C0392B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="5dp" />
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:hintEnabled="false"
                                app:suffixText="MN"
                                app:suffixTextColor="#888888">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etMontoFinanciar"
                                    android:layout_width="match_parent"
                                    android:layout_height="50dp"
                                    android:background="@drawable/bg_input"
                                    android:textSize="13sp"
                                    android:inputType="numberDecimal"
                                    android:hint="0.00" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginHorizontal="7dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="match_parent"
                                android:text="@string/nopagos"
                                android:fontFamily="serif"
                                android:textColor="#C0392B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="5dp" />
                            <EditText
                                android:id="@+id/etNumeroPagos"
                                android:layout_width="match_parent"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_input"
                                android:textSize="13sp"
                                android:paddingHorizontal="14dp"
                                android:inputType="number"
                                android:hint="0" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="7dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/tasainteres"
                                android:fontFamily="serif"
                                android:textColor="#C0392B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="5dp" />
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:hintEnabled="false"
                                app:suffixText="%"
                                app:suffixTextColor="#888888">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etTasaInteres"
                                    android:layout_width="match_parent"
                                    android:layout_height="50dp"
                                    android:background="@drawable/bg_input"
                                    android:paddingHorizontal="14dp"
                                    android:textSize="13sp"
                                    android:inputType="numberDecimal"
                                    android:hint="0" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EDE9E2"
                        android:layout_marginVertical="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCalcular"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="@string/calcular"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            app:backgroundTint="#C0392B"
                            app:cornerRadius="10dp"
                            android:layout_marginEnd="10dp" />
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLimpiar"
                            android:layout_width="wrap_content"
                            android:layout_height="44dp"
                            android:text="@string/limpiarbot"
                            android:textAllCaps="false"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            app:backgroundTint="#888888"
                            app:cornerRadius="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!--  Resumen -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/contenedorResumenPagos"
                    android:layout_width="280dp"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#1A1A2E"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/resumen"
                            android:textColor="#80FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="14dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_number_circle"
                            android:backgroundTint="#12FFFFFF"
                            android:padding="14dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="8dp">
                                <TextView
                                    android:id="@+id/tvResumenPagos1Cantidad"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="@string/pagosde"
                                    android:textColor="#99FFFFFF"
                                    android:textSize="15sp" />
                                <TextView
                                    android:id="@+id/tvResumenPagos1Monto"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$0.00"
                                    android:textColor="#7FDBCA"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <TextView
                                    android:id="@+id/tvResumenPagos2Cantidad"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text=""
                                    android:textColor="#99FFFFFF"
                                    android:textSize="15sp" />
                                <TextView
                                    android:id="@+id/tvResumenPagos2Monto"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text=""
                                    android:textColor="#7FDBCA"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>



                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#12FFFFFF"
                            android:layout_marginVertical="10dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <!-- Table Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8E4DC">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/white"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="serif"
                        android:gravity="center"
                        android:text="@string/tablacalculada"
                        android:textColor="#C0392B"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/mostrar"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        app:tint="@color/error_red"
                        android:background="@color/white"
                        android:src="@drawable/ic_ojo" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_card_borde"
                        android:backgroundTint="#E8E4DC">

                        <!--  Header de la tabla -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:background="#1A1A2E"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="44dp" android:layout_height="wrap_content" android:text="No." android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="center" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="@string/fechapago" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="center" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="@string/monto" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="center" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Capital" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="center" android:visibility="gone" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="@string/interes" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="center" android:visibility="gone" />
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="@string/capacumulado" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="center" android:visibility="gone" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="@string/saldo" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" android:gravity="center" />
                        </LinearLayout>

                        <!-- fila 0 Saldo Inicial -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="36dp"
                            android:orientation="horizontal"
                            android:background="#2C3E50"
                            android:gravity="center_vertical">
                            <TextView android:layout_width="44dp" android:layout_height="wrap_content" android:text="0" android:textColor="@color/white" android:textSize="15sp" android:gravity="center" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="—" android:textColor="#99FFFFFF" android:textSize="15sp" android:gravity="center" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="—" android:textColor="#99FFFFFF" android:textSize="15sp" android:gravity="center" />
                            <!-- Visibility controlled by logic -->
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="—" android:textColor="#99FFFFFF" android:textSize="15sp" android:gravity="center" android:visibility="gone" />
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="—" android:textColor="#99FFFFFF" android:textSize="15sp" android:gravity="center" android:visibility="gone" />
                            <TextView android:layout_width="120dp" android:layout_height="wrap_content" android:text="—" android:textColor="#99FFFFFF" android:textSize="15sp" android:gravity="center" android:visibility="gone" />
                            <TextView android:id="@+id/tvSaldoInicial" android:layout_width="100dp" android:layout_height="wrap_content" android:text="$0.00" android:textColor="#7FDBCA" android:textSize="11sp" android:textStyle="bold" android:gravity="center" />
                        </LinearLayout>

                        <!-- Content Rows Container -->
                        <LinearLayout
                            android:id="@+id/contenedorFilasTabla"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@color/white" />
                        
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnviar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/btn_continuar"
            android:text="@string/enviar"
            android:textSize="15dp"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_enviar"
            app:iconGravity="textEnd"
            app:iconSize="20dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
