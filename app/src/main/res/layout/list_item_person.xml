<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:gravity="center_vertical"
    android:background="#FFFFFF">


    <CheckBox
        android:id="@+id/checkbox"
        android:layout_width="20dp"
        android:layout_height="match_parent"></CheckBox>
    <View
        android:layout_width="4dp"
        android:layout_height="1dp" />
    <TextView
        android:id="@+id/textNombre"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="serif"
        android:textColor="#000000"
        android:textSize="13sp"
        tools:text="Nombre" />

    <TextView
        android:id="@+id/textCumple"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="serif"
        android:textColor="#000000"
        android:textSize="13sp"
        tools:text="Cumpleaños" />

    <TextView
        android:id="@+id/textOcupacion"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:fontFamily="serif"
        android:textColor="#000000"
        android:textSize="13sp"
        tools:text="Ocupación" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textParentesco"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="serif"
            android:textColor="#000000"
            android:textSize="13sp"
            android:ellipsize="end"
            android:maxLines="1"
            tools:text="Parentesco" />


        <View
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFirma"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="80dp"
            android:layout_height="38dp"
            android:backgroundTint="@color/pacificaazul"
            android:padding="0dp"
            android:text="@string/firmas"
            android:textColor="#FFFFFF"
            android:textStyle="normal"
            android:textSize="12sp"
            android:textAllCaps="false"
            app:cornerRadius="4dp"
            app:iconGravity="textEnd"
            app:iconPadding="5dp"
            android:visibility="invisible"
            app:iconTint="@color/white" />


    </LinearLayout>
</LinearLayout>