<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView style="@style/FieldLabel" android:text="Street Address" />
    <TextView android:id="@+id/tvUsaCalle" style="@style/FieldInput" android:layout_marginBottom="4dp" android:inputType="text" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
            <TextView style="@style/FieldLabel" android:text="City" />
            <TextView android:id="@+id/tvUsaCity" style="@style/FieldInput" android:inputType="text" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="@style/FieldLabel" android:text="State" />

            <TextView
                android:id="@+id/tvUsaState"
                style="@style/FieldInput"
                android:inputType="text" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
            <TextView style="@style/FieldLabel" android:text="Zip Code" />
            <TextView android:id="@+id/tvUsaZip" style="@style/FieldInput" android:inputType="number" />
        </LinearLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView style="@style/FieldLabel" android:text="Neighborhood" />
            <TextView android:id="@+id/tvUsaNeighborhood" style="@style/FieldInput" android:inputType="text" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>