<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pacificagris">

    <!-- ═══════════════════════ HEADER ═══════════════════════ -->
    <LinearLayout
        android:id="@+id/headerEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pacificaazul"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_exit"
            android:scaleType="fitCenter"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Detalle del Contrato"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFechas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#99FFFFFF"
                android:textSize="14sp"
                android:text="Creado: ... | Modificado: ..." />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditToggle"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDITAR"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GUARDAR"
            android:visibility="gone"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp" />
    </LinearLayout>

    <!-- ═══════════════════════ SCROLL ═══════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerEdit">

        <LinearLayout
            android:id="@+id/mainContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- ─── IDIOMA ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Idioma" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <Spinner
                        android:id="@+id/spinnerIdioma"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="40dp"
                        android:background="@drawable/bg_input_selector"
                        android:backgroundTint="@null"
                        android:enabled="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── TITULARES ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_titular" app:tint="@color/white" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Titulares" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddTitular" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:id="@+id/containerTitulares"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── BENEFICIARIOS ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_titular" app:tint="@color/white" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Beneficiarios" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddBeneficiario" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:id="@+id/containerBeneficiarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── DOMICILIO Y NACIONALIDAD ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Domicilio y Nacionalidad" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Selección de País -->
                    <TextView style="@style/FieldLabel" android:text="País" />
                    <Spinner
                        android:id="@+id/spinnerPais"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="40dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/bg_input_selector"
                        android:backgroundTint="@null"
                        android:enabled="false" />

                    <LinearLayout
                        android:id="@+id/containerDireccionDinamica"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- Nacionalidad -->
                    <TextView style="@style/FieldLabel" android:text="Nacionalidad" android:layout_marginTop="8dp" />
                    <Spinner
                        android:id="@+id/spinnerNacionalidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="40dp"
                        android:background="@drawable/bg_input_selector"
                        android:backgroundTint="@null"
                        android:enabled="false"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CONTACTO (TELÉFONOS) ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Teléfonos" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddTelefono" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:id="@+id/containerTelefonos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CONTACTO (EMAILS) ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Correos Electrónicos" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddEmail" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <LinearLayout
                        android:id="@+id/containerEmails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <CheckBox
                        android:id="@+id/checkNoCorreo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="No cuenta con correo"
                        android:textSize="15sp"
                        android:minHeight="0dp"
                        android:padding="4dp"
                        android:enabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── REDES SOCIALES ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Redes Sociales" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <CheckBox
                        android:id="@+id/checkNoRedes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No cuenta con redes sociales"
                        android:textSize="15sp"
                        android:enabled="false" />
                    <LinearLayout
                        android:id="@+id/containerRedes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CONDICIONES DE VENTA ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Condiciones de Venta" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView style="@style/FieldLabel" android:text="Tipo de Venta" />
                    <Spinner
                        android:id="@+id/spinnerTipoVenta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="40dp"
                        android:layout_marginBottom="4dp"
                        android:background="@drawable/bg_input_selector"
                        android:backgroundTint="@null"
                        android:enabled="false"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Unidad" />
                            <Spinner
                                android:id="@+id/spinnerUnidad"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="40dp"
                                android:background="@drawable/bg_input_selector"
                                android:backgroundTint="@null"
                                android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Temporada" />
                            <Spinner
                                android:id="@+id/spinnerTemporada"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="40dp"
                                android:background="@drawable/bg_input_selector"
                                android:backgroundTint="@null"
                                android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Moneda" />
                            <Spinner
                                android:id="@+id/spinnerMoneda"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="40dp"
                                android:background="@drawable/bg_input_selector"
                                android:backgroundTint="@null"
                                android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Tipo de Cambio" />
                            <EditText android:id="@+id/editTipoCambio" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Precio Bruto" />
                            <EditText android:id="@+id/editPrecioBruto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Precio Neto" />
                            <EditText android:id="@+id/editPrecioNeto" style="@style/FieldInput" android:inputType="numberDecimal" android:focusable="false" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Monto a Cuenta" />
                            <EditText android:id="@+id/editMontoCuenta" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Tipo de Pago" />
                            <Spinner
                                android:id="@+id/spinnerTipoPago"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="40dp"
                                android:background="@drawable/bg_input_selector"
                                android:backgroundTint="@null"
                                android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView style="@style/SubsectionLabel" android:text="Contratos Monto a Cuenta" />
                    <EditText
                        android:id="@+id/editNoContratosMontoCta"
                        style="@style/FieldInput"
                        android:layout_width="80dp"
                        android:hint="Cant."
                        android:inputType="number"
                        android:maxLength="1"
                        android:enabled="false"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:id="@+id/containerContratosMontoCuenta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />

                    <TextView style="@style/FieldLabel" android:text="Enganche Total" />
                    <EditText android:id="@+id/editEngancheTotal" style="@style/FieldInput" android:inputType="numberDecimal" android:layout_marginBottom="4dp" android:hint="—" android:enabled="false"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Enganche ($)" />
                            <EditText android:id="@+id/editEngancheMonto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Enganche (%)" />
                            <EditText android:id="@+id/editEnganchePorcentaje" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Enganche Sala ($)" />
                            <EditText android:id="@+id/editEngancheSala" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Enganche Sala (%)" />
                            <EditText android:id="@+id/editEngancheSalaPorcentaje" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Eng. Diferido" />
                            <EditText android:id="@+id/editEngDiferidoMonto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="No. Pagos Eng" />
                            <EditText android:id="@+id/editNoPagosEng" style="@style/FieldInput" android:inputType="number" android:maxLength="1" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView style="@style/SubsectionLabel" android:text="Pagos Diferidos" />
                    <LinearLayout
                        android:id="@+id/containerPagosDiferidos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Varios" />
                            <EditText android:id="@+id/editVariosMonto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Saldo Enganche" />
                            <EditText android:id="@+id/editSaldoEnganche" style="@style/FieldInput" android:inputType="numberDecimal" android:focusable="false" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />
                    <TextView style="@style/FieldLabel" android:text="No. Descuentos" />
                    <EditText android:id="@+id/editNoDesc" style="@style/FieldInput" android:inputType="number" android:maxLength="1" android:hint="—" android:enabled="false" android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:id="@+id/containerDescuentos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Costo Contrato" />
                            <EditText android:id="@+id/editCostoContrato" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Pago Sala" />
                            <EditText android:id="@+id/editPagoSala" style="@style/FieldInput" android:inputType="numberDecimal" android:focusable="false" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView style="@style/FieldLabel" android:text="Costo Membresía" />
                    <EditText android:id="@+id/editCostoMembresia" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── REGALOS ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Regalos" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddRegalo" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <LinearLayout
                        android:id="@+id/containerRegalos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />
                    <TextView style="@style/SubsectionLabel" android:text="Comentarios " />
                    <EditText
                        android:id="@+id/editComentarios"
                        style="@style/FieldInput"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:gravity="top|start"
                        android:padding="8dp"
                        android:hint="Sin comentarios..."
                        android:textSize="14sp"
                        android:enabled="false"
                        android:singleLine="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── FINANCIAMIENTO ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Financiamiento" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Monto a Financiar" />

                            <EditText
                                android:id="@+id/editMontoFinanciar"
                                style="@style/FieldInput"
                                android:inputType="numberDecimal"
                                android:enabled="false"
                                android:hint="—" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Número de Pagos" />

                            <EditText
                                android:id="@+id/editNumPagos"
                                style="@style/FieldInput"
                                android:inputType="number"
                                android:enabled="false"
                                android:hint="—" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Tasa de Interés (%)" />

                            <EditText
                                android:id="@+id/editTasa"
                                style="@style/FieldInput"
                                android:inputType="numberDecimal"
                                android:enabled="false"
                                android:hint="—" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Tipo de Periodo" />

                            <Spinner
                                android:id="@+id/spinnerTipoPeriodo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_input_selector"
                                android:backgroundTint="@null"
                                android:enabled="false"
                                android:minHeight="40dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Año 1er Uso" />
                            <EditText android:id="@+id/editAnioUso" style="@style/FieldInput" android:inputType="number" android:enabled="false" android:hint="—" />
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="No. de Años" />
                            <EditText android:id="@+id/editNoAnios" style="@style/FieldInput" android:inputType="number" android:enabled="false" android:hint="—" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView style="@style/FieldLabel" android:text="Fecha Primer Pago" />
                    <EditText android:id="@+id/editFechaPrimerPago" style="@style/FieldInput" android:focusable="false" android:enabled="false" android:hint="—" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
