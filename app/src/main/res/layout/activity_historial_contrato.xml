<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pacificagris">

    <!-- ═══════════════════════ HEADER ═══════════════════════ -->
    <LinearLayout
        android:id="@+id/headerEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pacificaazul"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_exit"
            android:scaleType="fitCenter"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="Detalle del Contrato"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvCreacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:text="Creado: ... " />
        <TextView
            android:id="@+id/tvModificado"
            android:layout_marginStart="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#99FFFFFF"
            android:textSize="14sp"
            android:text="|  Modificado: ..." />
    </LinearLayout>


        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditToggle"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDITAR"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GUARDAR"
            android:visibility="gone"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:minHeight="0dp"
            android:paddingHorizontal="10dp" />
    </LinearLayout>

    <!-- ═══════════════════════ SCROLL ═══════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerEdit">

        <LinearLayout
            android:id="@+id/mainContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- ─── IDIOMA ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Idioma" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tvIdioma"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textStyle="normal"
                        style="@style/FieldLabel"
                        android:textSize="15dp"></TextView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── TITULARES ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_titular" app:tint="@color/white" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Titulares" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddTitular" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:id="@+id/containerTitulares"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── BENEFICIARIOS ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_titular" app:tint="@color/white" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Beneficiarios" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddBeneficiario" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:id="@+id/containerBeneficiarios"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── DOMICILIO Y NACIONALIDAD ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Domicilio y Nacionalidad" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <!-- Selección de País -->
                    <TextView style="@style/FieldLabel" android:text="País" />
                    <TextView
                        android:id="@+id/tvPais"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="15sp"/>

                    <LinearLayout
                        android:id="@+id/containerDireccionDinamica"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <!-- Nacionalidad -->
                    <TextView style="@style/FieldLabel" android:text="Nacionalidad" android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvNacionalidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CONTACTO (TELÉFONOS) ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Teléfonos" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddTelefono" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:id="@+id/containerTelefonos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="8dp" />
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CONTACTO (EMAILS) ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Correos Electrónicos" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddEmail" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <LinearLayout
                        android:id="@+id/containerEmails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <CheckBox
                        android:id="@+id/checkNoCorreo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="No cuenta con correo"
                        android:textSize="15sp"
                        android:minHeight="0dp"
                        android:padding="4dp"
                        android:enabled="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── REDES SOCIALES ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Redes Sociales" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddRed" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <CheckBox
                        android:id="@+id/checkNoRedes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No cuenta con redes sociales"
                        android:textSize="15sp"
                        android:enabled="false" />
                    <LinearLayout
                        android:id="@+id/containerRedes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── CONDICIONES DE VENTA ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Condiciones de Venta" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"

                    android:padding="8dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="5dp"
                      >
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1">
                            <TextView style="@style/FieldLabel" android:text="Tipo de Venta" />
                            <TextView
                                android:id="@+id/tvTipoVenta"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"

                            android:layout_weight="1">
                            <TextView style="@style/FieldLabel" android:text="No. Años Uso" />
                            <TextView
                                android:id="@+id/tvAniosUso"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"/>
                        </LinearLayout>

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="5dp"
                        >
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1">
                            <TextView style="@style/FieldLabel" android:text="Tipo Ocupación" android:textSize="15sp" />
                            <TextView
                                android:id="@+id/tvTipoOcupacion"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"/>

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_weight="1">
                            <TextView style="@style/FieldLabel" android:text="Año Primer Uso" />
                            <TextView
                                android:id="@+id/tvAnioPrimerUso"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"/>
                        </LinearLayout>

                    </LinearLayout>


                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Unidad" />
                            <TextView
                                android:id="@+id/tvUnidad"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Temporada" />
                            <TextView
                                android:id="@+id/tvTemporada"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Moneda" />
                            <TextView
                                android:id="@+id/tvMoneda"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="15sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Tipo de Cambio" />
                            <TextView
                                android:id="@+id/tvTipoCambio"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Precio Bruto" />
                            <TextView android:id="@+id/tvPrecioBruto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Precio Neto" />
                            <TextView android:id="@+id/tvPrecioNeto" style="@style/FieldInput" android:inputType="numberDecimal" android:focusable="false" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Monto a Cuenta" />
                            <TextView android:id="@+id/tvMontoCuenta" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Tipo de Pago" />
                            <TextView android:id="@+id/tvTipoPago" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>

                        </LinearLayout>
                    </LinearLayout>

                    <TextView style="@style/SubsectionLabel" android:text="Contratos Monto a Cuenta" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No. Contratos: "
                           ></TextView>
                        <TextView
                            android:id="@+id/tvNoContratosMontoCta"
                            android:layout_width="80dp"
                            android:inputType="number"
                            android:textStyle="normal"
                            style="@style/FieldLabel"
                            android:maxLength="1"
                            android:enabled="false"
                            android:layout_marginBottom="4dp" />
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/containerContratosMontoCuenta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />


                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Enganche total Monto" />
                            <TextView android:id="@+id/tvEngancheMonto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Enganche (%)" />
                            <TextView android:id="@+id/tvEnganchePorcentaje" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Enganche Sala Monto" />
                            <TextView android:id="@+id/tvEngancheSala" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Enganche Sala (%)" />
                            <TextView android:id="@+id/tvEngancheSalaPorcentaje" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Eng. Diferido" />
                            <TextView android:id="@+id/tvEngDiferidoMonto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="No. Pagos Eng" />
                            <TextView android:id="@+id/tvNoPagosEng" style="@style/FieldInput" android:inputType="number" android:maxLength="1" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView style="@style/SubsectionLabel" android:text="Pagos Diferidos" />
                    <LinearLayout
                        android:id="@+id/containerPagosDiferidos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Varios" />
                            <TextView android:id="@+id/tvVariosMonto" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Saldo Enganche" />
                            <TextView android:id="@+id/tvSaldoEnganche" style="@style/FieldInput" android:inputType="numberDecimal" android:focusable="false" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />
                    <TextView style="@style/FieldLabel" android:text="No. Descuentos" />
                    <TextView android:id="@+id/tvNoDesc" style="@style/FieldInput" android:inputType="number" android:maxLength="1" android:hint="—" android:enabled="false" android:layout_marginBottom="4dp"/>

                    <LinearLayout
                        android:id="@+id/containerDescuentos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
                            <TextView style="@style/FieldLabel" android:text="Costo Contrato" />
                            <TextView android:id="@+id/tvCostoContrato" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView style="@style/FieldLabel" android:text="Pago Sala" />
                            <TextView android:id="@+id/tvPagoSala" style="@style/FieldInput" android:inputType="numberDecimal" android:focusable="false" android:hint="—" android:enabled="false"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView style="@style/FieldLabel" android:text="Costo Membresía" />
                    <TextView android:id="@+id/tvCostoMembresia" style="@style/FieldInput" android:inputType="numberDecimal" android:hint="—" android:enabled="false"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── REGALOS ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="8dp" android:text="Regalos" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
                <ImageButton android:id="@+id/btnAddRegalo" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_add" android:background="?attr/selectableItemBackgroundBorderless" android:visibility="gone" app:tint="@color/white" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="@color/white"
                app:cardElevation="1dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">
                    <LinearLayout
                        android:id="@+id/containerRegalos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginVertical="6dp" />
                    <TextView style="@style/SubsectionLabel" android:text="Comentarios " />
                    <TextView
                        android:id="@+id/tvComentarios"
                        style="@style/FieldInput"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:gravity="top|start"
                        android:padding="8dp"
                        android:hint="Sin comentarios..."
                        android:textSize="14sp"
                        android:enabled="false"
                        android:singleLine="false" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ─── FINANCIAMIENTO ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:background="@drawable/bg_section_header"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="2dp"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:text="Financiamiento" android:fontFamily="serif" android:textColor="@color/white" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="6dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Monto a Financiar" />

                            <TextView
                                android:id="@+id/tvMontoFinanciar"
                                style="@style/FieldInput"
                                android:inputType="numberDecimal"
                                android:enabled="false"
                                android:hint="—" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Número de Pagos" />

                            <TextView
                                android:id="@+id/tvNumPagos"
                                style="@style/FieldInput"
                                android:inputType="number"
                                android:enabled="false"
                                android:hint="—" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Tasa de Interés (%)" />

                            <TextView
                                android:id="@+id/tvTasa"
                                style="@style/FieldInput"
                                android:inputType="numberDecimal"
                                android:enabled="false"
                                android:hint="—" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                style="@style/FieldLabel"
                                android:text="Tipo de Periodo" />

                            <TextView
                                android:id="@+id/tvTipoPeriodo"
                                style="@style/FieldInput"
                                android:inputType="numberDecimal"
                                android:enabled="false"
                                android:hint="—" />
                        </LinearLayout>
                    </LinearLayout>



                    <TextView style="@style/FieldLabel" android:text="Fecha Primer Pago" />
                    <TextView android:id="@+id/tvFechaPrimerPago" style="@style/FieldInput" android:focusable="false" android:enabled="false" android:hint="—" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>