<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="Detalle de Descuentos"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Descripción:"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/editDescModal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:paddingHorizontal="8dp"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Monto:"
            android:textColor="@color/black" />

        <EditText
            android:id="@+id/editMontoModal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_card"
            android:hint="$"
            android:inputType="numberDecimal"
            android:paddingHorizontal="8dp"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="MN"
            android:textColor="#909090"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Table Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Table Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#D9636368"
            android:orientation="horizontal"
            android:padding="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.4"
                android:gravity="center"
                android:text="No."
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:gravity="center"
                android:text="Desc. Descuento"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:gravity="center"
                android:text="Remisión"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Monto Rem."
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Monto Desc."
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Referencia"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Fixed height to force scroll after ~9 items -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDescuentos"
            android:layout_width="match_parent"
            android:layout_height="280dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgregar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="Agregar"
            android:textAllCaps="false"
            android:textColor="#4CAF50"
            android:textSize="10sp"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="#4CAF50"
            app:iconPadding="4dp"
            app:strokeColor="#4CAF50" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuitar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="Quitar"
            android:textAllCaps="false"
            android:textColor="#F44336"
            android:textSize="10sp"
            app:icon="@android:drawable/ic_menu_delete"
            app:iconTint="#F44336"
            app:iconPadding="4dp"
            app:strokeColor="#F44336" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuitarTodos"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="Quitar Todos"
            android:textAllCaps="false"
            android:textColor="#B71C1C"
            android:textSize="10sp"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconTint="#B71C1C"
            app:iconPadding="4dp"
            app:strokeColor="#B71C1C" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLimpiar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Limpiar"
            android:textAllCaps="false"
            android:textColor="#FF9800"
            android:textSize="10sp"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconTint="#FF9800"
            app:iconPadding="4dp"
            app:strokeColor="#FF9800" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvTotalDescuentos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="end"
        android:text="Total: $0.00"
        android:textColor="@color/black"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRegresar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Regresar"
            android:textAllCaps="false"
            android:textColor="#757575"
            app:strokeColor="#757575" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAceptar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="Aceptar"
            android:textAllCaps="false"
            android:textColor="#080C24"
            app:strokeColor="#080C24" />
    </LinearLayout>
</LinearLayout>
