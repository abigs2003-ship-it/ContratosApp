<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_dg"
    app:startDestination="@id/nav_titulares">

    <fragment
        android:id="@+id/nav_titulares"
        android:name="com.example.contrato.TitularesFragment"
        android:label="@string/datosgen"
        tools:layout="@layout/fragment_titulares">
        <action
            android:id="@+id/action_titulares_a_firmas"
            app:destination="@id/nav_firmas" />
        <action
            android:id="@+id/action_titulares_a_INE"
            app:destination="@id/nav_INE" />
        <action
            android:id="@+id/action_titulares_a_Pasaporte"
            app:destination="@id/nav_Pasaporte" />
    </fragment>

    <fragment
        android:id="@+id/nav_direcciones"
        android:name="com.example.contrato.PestañaDireccion.PestañaDireccionFragment"
        android:label="@string/condicionesbot"
        tools:layout="@layout/fragment_direccion" />
    <fragment
        android:id="@+id/nav_Pasaporte"
        android:name="com.example.contrato.Id.PasaporteFragment"
        tools:layout="@layout/fragment_pasaporte">
        <action
            android:id="@+id/action_pasaporte_a_titulares"
            app:destination="@id/nav_titulares" />
    </fragment>

    <fragment
        android:id="@+id/nav_firmas"
        android:name="com.example.contrato.FirmasFragment"
        android:label="Firma">
        <action
            android:id="@+id/action_firmas_a_titulares"
            app:destination="@id/nav_titulares" />
    </fragment>
    <fragment
        android:id="@+id/nav_INE"
        android:name="com.example.contrato.Id.INEFragment"
        android:label="INE"
        tools:layout="@layout/fragment_id">
        <action
            android:id="@+id/action_ine_a_titulares"
            app:destination="@id/nav_titulares" />
    </fragment>


    <fragment
        android:id="@+id/nav_redes_sociales"
        android:name="com.example.contrato.RedesSocialesFragment"
        android:label="@string/condicionesbot"
        tools:layout="@layout/fragment_redes" />

</navigation>
